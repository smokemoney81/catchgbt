{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:react/recommended",
    "plugin:react-hooks/recommended"
  ],
  "parserOptions": {
    "ecmaFeatures": {
      "jsx": true
    },
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "react/prop-types": "off",
    "no-console": ["warn", { "allow": ["warn", "error", "log"] }],
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "error",
    "no-var": "error",
    "prefer-const": "warn",
    "eqeqeq": ["error", "always"],
    "curly": ["error", "all"],
    "semi": ["error", "always"],
    "quotes": ["error", "single", { "avoidEscape": true }],
    "indent": ["error", 2],
    "linebreak-style": ["error", "unix"],
    "comma-dangle": ["error", "only-multiline"],
    "no-trailing-spaces": "error",
    "no-multiple-empty-lines": ["error", { "max": 2 }],
    "space-before-function-paren": ["error", {
      "anonymous": "always",
      "named": "never",
      "asyncArrow": "always"
    }],
    "object-curly-spacing": ["error", "always"],
    "array-bracket-spacing": ["error", "never"],
    "keyword-spacing": ["error", { "before": true, "after": true }],
    "space-infix-ops": "error",
    "space-before-blocks": "error",
    "arrow-spacing": "error",
    "no-nested-ternary": "warn",
    "no-unreachable": "error",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-function-constructor-return": "error",
    "no-throw-literal": "error",
    "no-self-compare": "error",
    "no-constant-condition": "warn",
    "default-case": "warn",
    "default-case-last": "error",
    "no-fallthrough": "error",
    "prefer-template": "warn",
    "no-param-reassign": ["warn", { "props": false }],
    "no-shadow": ["warn", { "builtinGlobals": false, "hoist": "all", "allow": [] }],
    "no-use-before-define": ["error", { "functions": false, "classes": true, "variables": true }],
    "require-await": "error",
    "no-async-promise-executor": "error",
    "prefer-promise-reject-errors": "warn",
    "react-hooks/rules-of-hooks": "error",
    "react-hooks/exhaustive-deps": "warn",
    "react/no-unescaped-entities": "warn",
    "react/jsx-no-target-blank": "error",
    "react/display-name": "warn",
    "react/no-children-prop": "error",
    "react/no-danger-with-children": "error",
    "react/no-danger": "warn",
    "react/no-unstable-nested-components": ["warn", { "allowAsProps": false }],
    "react/no-array-index-key": "warn",
    "react/self-closing-comp": "warn",
    "react/jsx-key": "error",
    "react/no-string-refs": "error",
    "react/require-render-return": "error",
    "react/no-render-return-value": "error",
    "react/no-did-mount-set-state": "warn",
    "react/no-did-update-set-state": "warn",
    "react/no-comment-textnodes": "error",
    "react/no-find-dom-node": "error",
    "react/void-dom-elements-no-children": "error",
    "react/no-is-mounted": "error",
    "react/no-deprecated": "error",
    "react/jsx-no-comment-textnodes": "error",
    "react/jsx-no-duplicate-props": "error",
    "react/sort-prop-types": "off",
    "react/no-unescaped-entities": "off",
    "no-restricted-globals": [
      "error",
      {
        "name": "window.location.href",
        "message": "Use mobileStack.push(pageName) instead of window.location.href for navigation. This ensures MobileStackManager maintains navigation state correctly."
      },
      {
        "name": "window.location.replace",
        "message": "Use mobileStack.replace(pageName) instead of window.location.replace for navigation."
      },
      {
        "name": "window.history.pushState",
        "message": "Use mobileStack.push(pageName) instead of window.history.pushState for navigation."
      },
      {
        "name": "window.history.replaceState",
        "message": "Use mobileStack.replace(pageName) instead of window.history.replaceState for navigation."
      },
      {
        "name": "window.history.back",
        "message": "Use mobileStack.pop() instead of window.history.back() for navigation."
      },
      {
        "name": "window.history.forward",
        "message": "Direct forward navigation should use mobileStack.push() with the target page instead."
      }
    ],
    "no-restricted-syntax": [
      "error",
      {
        "selector": "MemberExpression[object.object.name='window'][object.property.name='location'][property.name=/^(href|replace|pathname|search|hash)$/]",
        "message": "Direct window.location manipulation bypasses MobileStackManager. Use mobileStack methods instead."
      },
      {
        "selector": "CallExpression[callee.object.object.name='window'][callee.object.property.name='history'][callee.property.name=/^(pushState|replaceState|back|forward|go)$/]",
        "message": "Direct window.history manipulation bypasses MobileStackManager. Use mobileStack methods instead."
      },
      {
        "selector": "AssignmentExpression[left.object.object.name='window'][left.object.property.name='location']",
        "message": "Assigning to window.location bypasses MobileStackManager. Use mobileStack.push() instead."
      }
    ]
  },
  "overrides": [
    {
      "files": ["src/lib/NavigationTracker.jsx", "src/lib/NavigationContext.jsx"],
      "rules": {
        "no-restricted-globals": "off",
        "no-restricted-syntax": "off"
      }
    },
    {
      "files": ["*.test.js", "*.test.jsx"],
      "env": {
        "jest": true
      }
    }
  ]
}